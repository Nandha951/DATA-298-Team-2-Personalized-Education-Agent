# API URL for the backend (if applicable)
VITE_API_URL=http://localhost:4000/api

# Finetuned model server (Modal endpoint or local FastAPI on port 8001)
# Set to Modal URL after deploying: modal deploy server.py
# Local fallback: http://localhost:8001/ask
FINETUNED_API_URL=http://localhost:8001/ask

# Timeout (ms) before falling back from finetuned model to DeepSeek API
FINETUNED_TIMEOUT_MS=30000

# LLM Provider API Keys
# Get your Gemini key at: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (Optional)
VITE_OPENAI_API_KEY=your_openai_api_key_here

# DeepSeek API Key (Optional)
VITE_DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Model Configurations
# Supported OpenAI models: gpt-4o, gpt-4o-mini, gpt-5-nano, etc.
VITE_OPENAI_MODEL=gpt-5-nano

# Supported DeepSeek models: deepseek-chat, deepseek-reasoner
VITE_DEEPSEEK_MODEL=deepseek-chat
